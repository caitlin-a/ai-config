# Ignore everything by default
*

# Track only config files
# settings.json is intentionally NOT tracked: it holds machine-specific
# paths (e.g. permission globs) that differ between Windows and macOS.
!.gitignore
!README.md
!CLAUDE.md
!rules/
!rules/**

# Track user-authored Claude Code config directories
!skills/
!skills/**
!agents/
!agents/**
!commands/
!commands/**

# Track memory files (stored under projects/[project-slug]/memory/)
!projects/
!projects/*/
!projects/*/memory/
!projects/*/memory/**
